source "Kconfig.zephyr"

config VALIDATE_PSA_IMPORT_MASTER_KEY
    bool "If the imported blobs should be validated by PSA operations for Master key operations"
    help
        Validate master key imported blob from flash

config VALIDATE_PSA_IMPORT_KEY_PAIR
    bool "Config can be used if the imported blobs need to be validated by KEY pair operations"
    help
        Validate Key pair imported blob from flash

config VALIDATE_PSA_IMPORT_CERT
    bool "Config can be used if the imported blobs need to parse the x509 certificate"
    help
        Validate x509 certificate imported blob from flash, it must have VALIDATE_PSA_IMPORT_KEY_PAIR enabled

config BLOB_AREA
    hex "Area where blobs are located"
    default 0x088B0000
    help
        Locate the Flash area where the blobs are located.

config BLOB_AREA_SIZE
    hex "Size of area where blobs are located"
    default 0x2000
    help
        Define the Flash area size where the blobs are located.